  "steps": [
    { "instruction": "Heat the olive oil in a large saucepan over medium-high heat. Add the onion and garlic and cook, stirring, for 3 minutes until the onion softens." },
    { "instruction": "Add the potato and leek and cook, stirring, for 5 minutes until the leek softens." },
    { "instruction": "Add the vegetable stock and bring to the boil. Reduce heat to medium and gently boil, uncovered, for 20 minutes until the potato is soft. Remove from heat and set aside for 10 minutes to cool." },
    {
      "_type": "Branch",
      "options": {
        "Blender": [
          { "instruction": "Transfer one-third of the potato mixture to a blender jug and blend until smooth. Pour into a clean saucepan. Repeat in two more batches with the remaining mixture." }
        ],
        "Stick blender": [
          { "instruction": "Use a stick blender to blend the soup directly in the saucepan until smooth." }
        ]
      }
    },
    { "instruction": "Place the blended soup over medium heat. Add the cream and stir to combine. Cook, stirring, for 5 minutes until hot. Season with salt to taste." },
    { "instruction": "Ladle the soup into bowls and top with croutons, chives, a drizzle of olive oil. Serve immediately." }
  ]
