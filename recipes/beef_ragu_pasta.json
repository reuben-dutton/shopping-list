  "steps": [
    { "instruction": "Pat the beef dry and season generously all over with salt and pepper." },
    { "instruction": "Heat 1 tbsp of olive oil in a large heavy-based pot over high heat. Sear the beef on all sides until very deeply browned, about 3–5 minutes total. Remove to a plate." },
    { "instruction": "Reduce heat to medium-low and add the remaining 2 tbsp of olive oil. Add the garlic and onion and sauté for 2 minutes. Add the carrots and celery and sauté slowly for 5 minutes." },
    { "instruction": "Add the crushed tomatoes, tomato paste, bouillon cubes, red wine, water, thyme, and bay leaves. Return the beef and any pooled juices to the pot. Raise heat to bring to a simmer, then reduce to low so the liquid bubbles very gently." },
    { "instruction": "Cover and cook for 2 hours, or until the beef is tender enough to shred." },
    { "instruction": "Remove the beef and coarsely shred with two forks. Return the shredded beef to the pot. Simmer uncovered for 30 minutes until the sauce reduces and thickens." },
    { "instruction": "Taste and adjust seasoning with salt and pepper. Add up to 1/2 tsp sugar if the sauce is too sharp. Cover and set aside until ready to serve." },
    { "instruction": "Bring a very large pot of salted water to the boil. Cook the pappardelle for 1 minute less than the packet instructions." },
    { "instruction": "While the pasta cooks, heat 5 cups of ragu in a large frying pan or Dutch oven over high heat." },
    { "instruction": "Transfer the cooked pasta directly into the pan using tongs. Add 3/4 cup of pasta water. Toss for 1–2 minutes until the sauce reduces and clings to the pasta." },
    { "instruction": "Serve immediately with plenty of freshly grated parmesan and parsley if desired." }
  ]
