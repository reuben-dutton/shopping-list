      "steps": [
        {
          "instruction": "Place the birds eye chilli, garlic, coriander stems and a pinch of salt into a mortar and pestle. Grind until a smooth paste forms."
        },
        {
          "instruction": "Add the sugar, fish sauce, lime juice and grapeseed oil. Stir to combine and adjust the balance of sugar, lime juice and fish sauce to taste."
        }
      ],
      "window": "2 hours"
    }
  ],
  "steps": [
    {
      "instruction": "Prepare the Thai Dressing and set aside."
    },
    {
      "instruction": "Preheat a skillet over high heat until screaming hot and smoking. Drizzle the beef with oil on both sides and sprinkle with salt and pepper. Cook to your liking: about 2 minutes per side for medium rare (internal temp 52\u00b0C/125\u00b0F) or 2\u00bd minutes per side for medium (57\u00b0C/135\u00b0F)."
    },
    {
      "instruction": "Remove beef from the skillet onto a plate. Loosely tent with foil and rest for 10 minutes."
    },
    {
      "instruction": "Place lettuce in a bowl, drizzle with 1 tbsp of the Thai Dressing and toss to coat."
    },
    {
      "instruction": "Slice the beef thinly against the grain. Combine in a bowl with the cherry tomatoes, red onion, cucumber, coriander leaves and mint. Dress with most of the remaining dressing and toss gently."
    },
    {
      "instruction": "Pile dressed lettuce onto plates, then pile over the beef and salad ingredients. Sprinkle with chopped peanuts, garnish with extra coriander and mint leaves if desired, and drizzle with any remaining dressing. Serve immediately."
    }
  ]
