  "steps": [
    {
      "instruction": "Heat oil in a wok over medium-high heat. Season chicken, then stir-fry in batches for 3–4 minutes until just golden. Remove chicken from wok and set aside."
    },
    {
      "instruction": "Add laksa paste to the wok and stir-fry for 1 minute until fragrant. Return the chicken and add the stock, coconut milk, makrut lime leaves and 125ml (½ cup) water. Bring to the boil, reduce heat to medium-low and simmer for 10 minutes until chicken is cooked through."
    },
    {
      "instruction": "Stir in palm sugar, fish sauce and lime juice to taste."
    },
    {
      "instruction": "Meanwhile, if using quail eggs, place in a saucepan and cover with cold water. Bring to the boil over high heat and cook for 3–4 minutes until hard-boiled. Rinse under cold water, then peel and halve. Set aside."
    },
    {
      "instruction": "Cook the vermicelli noodles according to packet instructions, then drain and divide among 4 serving bowls."
    },
    {
      "instruction": "Ladle laksa over the noodles. Top with bean sprouts, Thai basil, coriander, quail egg halves, fried shallots and sliced chilli. Serve immediately."
    }
  ]
