  "steps": [
    {
      "instruction": "Drain the canned pineapple chunks over a bowl, reserving \u00bd cup (125ml) of the juice. Set both aside separately."
    },
    {
      "instruction": "In a large non-stick skillet, heat oil over medium-high heat. Season chicken strips with salt and pepper and add to pan. Brown chicken and remove to plate."
    },
    {
      "instruction": "Add red and green peppers to the pan and cook for 1 minute."
    },
    {
      "instruction": "Stir in pineapple chunks, reserved juice, brown sugar, rice wine vinegar and chicken broth. Bring to a simmer and cook until the sauce begins to reduce."
    },
    {
      "instruction": "Stir in cornstarch mixture and return to a simmer. Stir in chicken strips and cook for 5 minutes."
    },
    {
      "instruction": "Serve over cooked rice."
    }
  ]
