  "steps": [
    {
      "instruction": "Working with one pork cutlet at a time, place between two pieces of plastic wrap and flatten with a meat mallet until about 1cm thick. Repeat with remaining cutlets."
    },
    {
      "instruction": "Combine panko crumbs, parmesan, parsley, and lemon rind in a bowl, season to taste and toss to combine. Lightly beat eggs and milk together in a separate large bowl."
    },
    {
      "instruction": "Lightly dust each cutlet in seasoned flour, coat with the egg wash, then press into the breadcrumb mixture, shaking off excess between each stage. Place on a baking tray and refrigerate until required."
    },
    {
      "instruction": "Prepare the Italian coleslaw: blanch peas in boiling salted water for 1-2 minutes until tender, refresh and drain. Combine peas with cabbage, fennel, onion, radishes, basil, mint, parsley, watercress, capers and parmesan in a large bowl. Set aside."
    },
    {
      "instruction": "Preheat oven to 160°C. Heat half the vegetable oil in a large frying pan over medium heat, add half the butter and heat until foaming. Cook cutlets in batches, turning once, until golden and cooked through (4-5 minutes each side). Drain on paper towel, then transfer to a lined baking tray and place in the oven to keep warm. Wipe the pan and repeat with remaining oil, butter and cutlets."
    },
    {
      "instruction": "Just before serving, dress the coleslaw with extra-virgin olive oil, chilli oil, and lemon juice. Season to taste and toss lightly."
    },
    {
      "instruction": "Season the cutlets to taste and serve hot with the Italian coleslaw, lemon wedges and Dijon mustard."
    }
  ]
