  "steps": [
    {
      "instruction": "Make the dill sauce ahead of time: whisk together sour cream, Dijon mustard, lemon juice, and dill until well blended. Refrigerate until ready to serve."
    },
    {
      "instruction": "Preheat the oven to 175°C (350°F). Line a baking sheet with foil and place a rack on top. Coat the rack with cooking spray."
    },
    {
      "instruction": "Combine breadcrumbs and milk in a large bowl and let soak for 10 minutes. Mix in the ground beef, ground pork, onion, parsley, celery, egg, garlic, sugar, salt, and pepper until combined — the mixture will be fairly wet."
    },
    {
      "instruction": "Using a tablespoon scoop, form the mixture into 36 meatballs and place on the prepared rack."
    },
    {
      "instruction": "Bake for about 18 minutes, until an instant-read thermometer inserted into the centre reads 71°C (160°F)."
    },
    {
      "instruction": "Serve the meatballs immediately with the chilled dill sauce alongside."
    }
  ]
