  "steps": [
    {
      "instruction": "Marinate the sliced rump steak in the pre-prepared beef marinade for at least 10 minutes."
    },
    {
      "instruction": "Heat a cup or two of water in the wok until boiling. Add about a teaspoon of the peanut oil and blanch the broccoli for about 1 minute, until bright green and slightly softened. Remove and set aside."
    },
    {
      "instruction": "Drain the water from the wok and dry over the flame. Add the remaining peanut oil, then the ginger first, followed by the garlic, then the onion. Fry until the onion softens, then remove these aromatics and add them to the broccoli."
    },
    {
      "instruction": "Using the flavoured oil remaining in the wok, fry the marinated beef in batches until well browned. Return all ingredients to the wok and toss together."
    },
    {
      "instruction": "Add the oyster sauce, soy sauce, beef stock, and sugar and toss to coat. Slowly drizzle the cornflour slurry into the wok while tossing, until the sauce thickens and clings to the ingredients."
    },
    {
      "instruction": "Remove to a plate, rest for a minute, and serve with rice."
    }
  ]
