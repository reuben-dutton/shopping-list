  "steps": [
    {
      "instruction": "Heat the sesame oil in a large saucepan over medium-high heat. Add the meatballs and cook, turning, for 5 minutes or until browned. Transfer to a heatproof bowl."
    },
    {
      "instruction": "Add the capsicum to the pan and cook for 1 minute or until just tender. Add the stock, fish sauce, soy sauce, ginger, star anise and 1 litre of water. Bring to the boil."
    },
    {
      "instruction": "Return the meatballs to the pan along with the noodles. Cook for 2 minutes or until the noodles are tender and meatballs are cooked through. Add the pak choy and simmer for 1 minute or until just wilted. Season and divide among serving bowls."
    }
  ]
