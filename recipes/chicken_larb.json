  "steps": [
    { "instruction": "Heat a wok or large skillet over medium-high heat. Add the oil. When hot, add the chiles, shallot, and garlic and cook, stirring constantly, for 1–2 minutes until the shallot is translucent. Do not let the garlic brown." },
    { "instruction": "Add the ground chicken and cook, breaking it apart with a wooden spoon, for 4–5 minutes until cooked through and no longer pink." },
    { "instruction": "Add the red onion and scallions and toss for 1–2 minutes until warmed through but not fully softened." },
    { "instruction": "Stir in the larb sauce and toss to combine. If using rice powder, sprinkle in a spoonful and toss; add more to taste for a thicker texture." },
    { "instruction": "Remove from the heat. Stir through the fresh cilantro, mint, and basil (if using). Taste and adjust: more chiles for heat, fish sauce for saltiness, sugar for sweetness, or lime juice for tartness." },
    { "instruction": "Serve warm or at room temperature with sticky rice, lettuce or cabbage leaves, sliced cucumbers, carrot sticks, green beans, and lime wedges." },
    {
      "_type": "Branch",
      "options": {
        "With rice powder (optional thickener)": [
          { "instruction": "In a dry pan over medium-low heat, toast the raw rice, stirring often, for about 10 minutes until fragrant and medium golden brown." },
          { "instruction": "Transfer to a food processor or blender and grind to a coarse powder. Sprinkle into the larb as directed in Step 4." }
        ],
        "Without rice powder": [
          { "instruction": "Skip the rice powder. Optionally substitute a small cornstarch-and-water slurry as a thickener if desired." }
        ]
      }
    }
  ]
