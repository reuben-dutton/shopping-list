  "steps": [
    {
      "instruction": "Remove string from pork. Remove and discard rind. Heat oil in a large frying pan over medium-high heat. Add pork and cook, turning occasionally, for 8 minutes or until browned all over."
    },
    {
      "instruction": "Meanwhile, place mushrooms, lemongrass, ginger, garlic and star anise in the base of a 5.5-litre slow cooker. Whisk curry paste, tamarind, sugar, stock powder and coconut milk together in a bowl."
    },
    {
      "instruction": "Place pork in slow cooker. Pour over coconut mixture. Cover and cook on HIGH for 4 hours 30 minutes or until pork is tender."
    },
    {
      "instruction": "Cook gai larn and broccolini in a saucepan of boiling salted water for 2 minutes or until just tender. Drain."
    },
    {
      "instruction": "Transfer pork to a serving platter. Arrange vegetables around pork. Drizzle with sauce. Top with coriander sprigs, halved chilli and fried shallots. Serve with steamed jasmine rice."
    }
  ]
