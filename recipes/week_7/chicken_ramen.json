            "intrinsics": ["unsalted"],
            "preparation": [],
            "category": "Dairy & Eggs",
            "optional": false,
            "staple": true
          }
        ],
        "steps": [
          {
            "instruction": "Preheat oven to 375°F (190°C). Season chicken generously with salt and pepper."
          },
          {
            "instruction": "Melt butter in a large oven-safe skillet over medium heat. Add chicken skin-side down and cook until the skin is golden brown and releases easily, about 5-7 minutes. Flip and cook for another 4-5 minutes until golden."
          },
          {
            "instruction": "Transfer skillet to the oven and roast for 15-20 minutes until cooked through. Remove, transfer chicken to a plate and cover with foil until ready to serve."
          }
        ]
    },
