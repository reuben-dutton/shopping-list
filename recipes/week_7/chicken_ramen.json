      "staple": false
    }
  ],
  "steps": [
    {
      "instruction": "Make the pan-roasted chicken per the sub-recipe. Once cooked, slice thinly and set aside, covered with foil to keep warm."
    },
    {
      "instruction": "Heat oil in a large pot over medium heat until shimmering. Add garlic and ginger and cook for a few minutes until softened. Add soy sauce and mirin, stir to combine and cook for another minute."
    },
    {
      "instruction": "Add the chicken stock, cover and bring to a boil. Remove the lid and simmer uncovered for 5 minutes, then add the dried mushrooms. Simmer gently for a further 10 minutes. Season with salt to taste."
    },
    {
      "instruction": "Bring a separate pot of water to the boil. Gently lower in the cold eggs and simmer for 7 minutes (slightly runny yolk) or 8 minutes (soft but set yolk). Transfer to an ice bath for at least 5 minutes, then peel and halve lengthwise."
    },
    {
      "instruction": "Add the ramen noodles to the boiling egg water and cook for 2-3 minutes until soft. Divide noodles into two large bowls."
    },
    {
      "instruction": "Ladle broth over noodles. Top with sliced chicken, spring onion, soft-boiled egg and jalapeño if using. Serve immediately."
    }
  ]
