  "steps": [
    {
      "instruction": "Heat 1 tbsp oil in a large non-stick frying pan. Add the paneer and fry gently until crisp. Remove with a slotted spoon and set aside."
    },
    {
      "instruction": "Add the remaining oil and the cauliflower to the pan, and cook for 10 minutes until browned. Add the onions (and a little more oil if needed) and cook for a further 5 minutes until softened."
    },
    {
      "instruction": "Stir in the garlic and curry paste, then pour in the passata and 250ml water. Season, bring to a simmer, then cover and cook for 18-20 minutes or until the cauliflower is just tender."
    },
    {
      "instruction": "Add the frozen peas and crispy paneer to the pan and cook for a further 5 minutes."
    },
    {
      "instruction": "Stir through most of the coriander and garnish with the rest. Serve with basmati rice or naan bread, and raita or chutney."
    }
  ]
