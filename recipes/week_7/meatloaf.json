  "steps": [
    {
      "instruction": "Preheat oven to 180°C."
    },
    {
      "instruction": "Combine sausage mince, beef mince, breadcrumbs, onion, curry powder, salt, pepper, parsley and egg in a bowl. Mix with clean hands until smooth. Add milk and water as needed to bring the mixture together."
    },
    {
      "instruction": "Shape meat mixture into a loaf and place in a greased baking dish (or press into a loaf tin). Bake for 30 minutes."
    },
    {
      "instruction": "Meanwhile, make the BBQ sauce: combine all sauce ingredients in a saucepan, bring slowly to the boil, then reduce heat and simmer for 5 minutes."
    },
    {
      "instruction": "Remove meatloaf from oven and carefully pour off any surplus fat. Pour BBQ sauce over meatloaf, return to oven and bake for a further 45 minutes, basting frequently with sauce."
    }
  ]
