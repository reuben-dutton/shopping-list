  "steps": [
    { "instruction": "Heat 1 tbsp of the olive oil and half the butter (from the mushroom portion) in a large heavy-based pot over high heat. Once melted, add half the sliced mushrooms and cook until well golden, about 4 minutes." },
    { "instruction": "Add half the garlic, a quarter teaspoon each of salt and pepper, and continue to cook until golden, about 1.5 minutes more. Remove mushrooms to a bowl. Repeat with remaining mushrooms and garlic, then remove." },
    { "instruction": "Turn heat to medium. In the same pot, melt the risotto butter. Add the remaining garlic and the eschallots and cook for 2 minutes until translucent but not golden." },
    { "instruction": "Add the wine and simmer rapidly for 2 minutes, scraping the base of the pot, until mostly evaporated." },
    { "instruction": "Add the rice and stir for 1 minute until semi-translucent." },
    { "instruction": "Add about 1.5 cups of warm stock. Stir, then leave for 3 minutes (stirring a few times) until mostly absorbed. Repeat twice more in 1.5-cup additions, stirring occasionally each time, until all stock is used and the rice is just cooked but the risotto is still loose and creamy (about 10 minutes total)." },
    { "instruction": "Add the cream and butter (if using) and stir vigorously to make it creamy." },
    { "instruction": "Stir in the parmesan, and remaining salt and pepper. Taste and adjust seasoning." },
    { "instruction": "Stir through half the cooked mushrooms. The consistency should be creamy and oozy, not stodgy." },
    { "instruction": "Reheat the remaining mushrooms (e.g. in the microwave)." },
    { "instruction": "Spoon the risotto into bowls and top with the reserved mushrooms (and any buttery juices). Garnish with parsley or chives and extra parmesan. Serve immediately." }
  ]
